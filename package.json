{
  "name": "@readme/syntax-highlighter",
  "version": "15.0.0",
  "description": "ReadMe's React-based syntax highlighter",
  "homepage": "https://readmeio.github.io/syntax-highlighter/",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/readmeio/syntax-highlighter.git"
  },
  "main": "dist/index.node.js",
  "browser": "dist/index.js",
  "exports": {
    ".": {
      "browser": "./dist/index.js",
      "require": "./dist/index.node.js",
      "node": "./dist/index.node.js"
    },
    "./browser": {
      "browser": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./utils": {
      "require": "./dist-utils/index.js",
      "default": "./dist-utils/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "webpack --progress && tsc",
    "format": "npx oxlint --fix && npx oxfmt --write",
    "lint": "knip && npx oxlint && npx oxfmt --check",
    "prebuild": "rm -rf dist && rm -rf dist-utils",
    "prepack": "npm run build",
    "pretest": "npm run lint && tsc --noEmit",
    "start": "webpack serve --open --config ./webpack.config.dev.js",
    "test": "vitest run --coverage",
    "watch": "webpack -w --progress"
  },
  "dependencies": {
    "codemirror": "^5.54.0",
    "codemirror-graphql": "1.3.2",
    "prop-types": "^15.7.2",
    "react-codemirror2": "^8.0.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.24.4",
    "@babel/preset-react": "^7.24.1",
    "@csstools/css-parser-algorithms": "^4.0.0",
    "@readme/oxlint-config": "^1.1.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-loader": "^10.0.0",
    "css-loader": "^7.1.1",
    "html-webpack-plugin": "^5.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.10.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "sass": "^1.89.2",
    "sass-loader": "^13.3.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.0.4"
  },
  "peerDependencies": {
    "@readme/variable": "^18.0.0",
    "react": "18.x",
    "react-dom": "18.x"
  },
  "engines": {
    "node": ">=22"
  }
}
